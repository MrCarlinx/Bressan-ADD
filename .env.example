# Copie para .env e preencha com seus valores reais.
# NUNCA versione o arquivo .env com senhas reais.

APP_ENV=local

DB_HOST=localhost
DB_NAME=toca_do_coelho
DB_USER=toca_app
DB_PASS=sua_senha_segura_aqui

# Token obrigatório para executar install_db.php via navegador (recomendado: usar só CLI)
INSTALL_TOKEN=altere_para_um_token_longo_e_aleatorio

# Usuário admin criado na instalação (php scripts/install_db.php)
ADMIN_EMAIL=admin@tocadocoelho.com.br
ADMIN_PASS=SenhaForte123
